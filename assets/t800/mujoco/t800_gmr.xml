    <joint damping="1.0" armature="0.01" limited="true" />
    <geom type="capsule" size="0.03" rgba="0.78 0.78 0.82 1" />
    <default class="visual_mesh">
      <geom type="mesh" contype="0" conaffinity="0" density="0" group="2" rgba="0.82 0.82 0.86 1" />
    </default>
    <default class="collision_proxy">
      <geom group="3" rgba="1 0.5 0 0" />
